---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

const title = 'Wanderings and Misadventures';
const description = 'A site of Brooke Storm\'s thoughts and ramblings.';
---

<BaseLayout title={title} description={description}>
  <main class="shell">
    <section class="terminal" aria-labelledby="site-title">
      <div class="screen-label" aria-hidden="true">CROOKEDSTORM-64</div>
      <p class="eyebrow">READY.</p>
      <h1 id="site-title" class="sr-only">Wanderings and Misadventures</h1>
      <pre class="ascii-title" aria-hidden="true">+--------------------------------+
| W A N D E R I N G S            |
|        A N D                   |
| M I S A D V E N T U R E S      |
+--------------------------------+</pre>
      <p class="command-line">
        <span aria-hidden="true">LOAD</span> "THOUGHTS AND RAMBLINGS",8,1
      </p>
      <p>
        Welcome, traveler. You have found Brooke’s campfire at the edge of the network.
        The map is cluttered with homelab experiments, overland routes, geocache clues,
        photographs, and assorted misadventures.
      </p>
      <nav aria-label="Site versions">
        <a class="button-link" href="/legacy/">Browse the archives</a>
      </nav>
      <noscript>
        <p>
          JavaScript will eventually enable the boot sequence and interactive world. Content will remain available without it.
        </p>
      </noscript>
    </section>
  </main>
</BaseLayout>
