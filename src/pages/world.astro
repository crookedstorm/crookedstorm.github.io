---
import SiteNav from '../components/SiteNav.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

const title = 'World | Wanderings and Misadventures';
const description =
  'A small interactive gateway to Wanderings and Misadventures.';
---

<BaseLayout title={title} description={description}>
  <main class="page-shell">
    <article class="page-panel world-panel">
      <SiteNav />
      <p class="eyebrow">WORLD GATEWAY</p>
      <h1>Choose a Path</h1>
      <p>
        Use arrow keys, WASD, or the direction pad to move. Arrive at a
        destination door to open that section.
      </p>
      <canvas
        id="world-canvas"
        class="world-canvas"
        width="736"
        height="480"
        aria-label="Interactive map with paths to About, Blog, and Projects"
      >
        The interactive map requires Canvas support. Use the links below to
        browse the site.
      </canvas>
      <div class="world-direction-pad" role="group" aria-label="World movement">
        <button
          class="world-direction-button world-direction-button-up"
          type="button"
          data-world-direction="up"
          aria-label="Move up"
        >
          ▲
        </button>
        <button
          class="world-direction-button world-direction-button-left"
          type="button"
          data-world-direction="left"
          aria-label="Move left"
        >
          ◀
        </button>
        <button
          class="world-direction-button world-direction-button-down"
          type="button"
          data-world-direction="down"
          aria-label="Move down"
        >
          ▼
        </button>
        <button
          class="world-direction-button world-direction-button-right"
          type="button"
          data-world-direction="right"
          aria-label="Move right"
        >
          ▶
        </button>
      </div>
      <p id="world-status" class="world-status">
        <span id="world-status-message" aria-live="polite"
          >Standing at camp.</span
        >
        <span id="world-score">Score: 0</span>
      </p>
      <nav class="world-links" aria-label="World destinations">
        <a class="button-link" href="/about/">About</a>
        <a class="button-link" href="/blog/">Blog</a>
        <a class="button-link" href="/projects/">Projects</a>
      </nav>
    </article>
  </main>
  <script>
    import '../scripts/world.ts';
  </script>
</BaseLayout>
