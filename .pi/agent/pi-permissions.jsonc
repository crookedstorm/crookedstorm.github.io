{
  "$schema": "./npm/node_modules/pi-permission-system/schemas/permissions.schema.json",
  "bash": {
    "*": "ask",
    "npm *": "allow"
  },
  "defaultPolicy": {
    "bash": "ask",
    "mcp": "ask",
    "skills": "ask",
    "special": "ask",
    "tools": "ask"
  },
  "mcp": {
    "*": "allow"
  },
  "skills": {
    "*": "allow"
  }
}
